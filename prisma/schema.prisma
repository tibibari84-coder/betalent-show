// BETALENT — auth, onboarding, show orchestration, formal auditions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SeasonStatus {
  DRAFT
  UPCOMING
  LIVE
  COMPLETED
  ARCHIVED
}

enum StageType {
  AUDITION
  CALLBACK
  SEMIFINAL
  FINAL
  SPECIAL
}

enum StageStatus {
  DRAFT
  UPCOMING
  OPEN
  JUDGING
  VOTING
  RESULTS
  COMPLETED
  ARCHIVED
}

enum EpisodeStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

/// When the window accepts entries (lifecycle separate from Stage show-state).
enum AuditionWindowStatus {
  DRAFT
  UPCOMING
  OPEN
  CLOSED
  REVIEW
  COMPLETED
  ARCHIVED
}

enum AuditionSubmissionType {
  ORIGINAL_SONG
  ORIGINAL_TOPLINE
  ORIGINAL_INSTRUMENTAL
}

enum AuditionRightsStatus {
  UNKNOWN
  ELIGIBLE
  REVIEW_REQUIRED
  REJECTED_RIGHTS
}

enum AuditionSubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
  ARCHIVED
}

enum AuditionReviewDecisionStatus {
  PENDING
  ACCEPTED
  REJECTED
  NEEDS_REVIEW
}

/// Show-facing participant status (distinct from account / AuditionSubmission).
enum ContestantStatus {
  ACTIVE
  PAUSED
  ELIMINATED
  WINNER
  ARCHIVED
}

/// Official performance appearance type (aligned with competition structure).
enum PerformanceKind {
  AUDITION
  CALLBACK
  SEMIFINAL
  FINAL
  SPECIAL
}

/// Lifecycle of the official show object (`Performance`).
enum PerformanceStatus {
  DRAFT
  ACCEPTED
  SCHEDULED
  PUBLISHED
  JUDGED
  COMPLETED
  ARCHIVED
}

/// Publication lifecycle for a stage result package (`StageResult`).
enum StageResultStatus {
  DRAFT
  LOCKED
  PUBLISHED
  ARCHIVED
}

/// Official advancement / elimination outcome (not editorial copy).
enum AdvancementDecisionKind {
  ADVANCED
  ELIMINATED
  HOLD
  PENDING
  WINNER
  RUNNER_UP
  WILDCARD
}

/// Where an editorial slot may appear (curated presentation — not competition truth).
enum EditorialPageScope {
  HOME
  SHOW
  RESULTS
  PROFILE
  ARCHIVE
  GLOBAL
}

enum EditorialSlotStatus {
  ACTIVE
  INACTIVE
}

enum EditorialTargetType {
  SEASON
  STAGE
  EPISODE
  PERFORMANCE
  CONTESTANT
  STAGE_RESULT
}

enum EditorialPlacementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// AI layer role — interpretive only; never official competition truth.
enum AIOutputKind {
  JUDGE
  HOST
  PRODUCER
}

/// Explicit anchor for persisted AI outputs (exactly one FK pair must match targetType).
enum AIOutputTargetType {
  PERFORMANCE
  STAGE
  EPISODE
  STAGE_RESULT
  EDITORIAL_PLACEMENT
}

enum AIOutputStatus {
  DRAFT
  GENERATED
  REVIEWED
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum VideoAssetStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
  DELETED
}

enum VideoAssetProvider {
  CLOUDFLARE_STREAM
  R2_OBJECT
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum JudgeResultStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum AdvancementStatus {
  PENDING
  ADVANCED
  ELIMINATED
  HOLD
}

enum ArchiveRecordStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum NotificationType {
  EMAIL
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String?
  displayName           String?
  username              String?   @unique
  avatarUrl             String?
  city                  String?
  country               String?
  role                  UserRole  @default(USER)
  wantsToAudition       Boolean   @default(false)
  onboardingCompletedAt DateTime?
  emailVerifiedAt       DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  sessions               Session[]
  auditionSubmissions    AuditionSubmission[]
  auditionReviewsWritten AuditionReview[] @relation("AuditionReviewer")
  contestant             Contestant?
  videoAssets            VideoAsset[]
  submissions            Submission[]
  judgeResults           JudgeResult[]
  auditLogs              AuditLog[]
  notifications          Notification[]
  emailLogs              EmailLog[]
  creatorProfile         CreatorProfile?
  likes                  SubmissionLike[]
  views                  SubmissionViewEvent[]
  following              CreatorFollow[] @relation("CreatorFollowFollower")
  followers              CreatorFollow[] @relation("CreatorFollowCreator")
  engagementStat         UserEngagementStat?
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Season {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String?
  status      SeasonStatus @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  stages      Stage[]
  episodes    Episode[]
  auditionWindows     AuditionWindow[]
  performances        Performance[]
  stageResults        StageResult[]
  advancementDecisions AdvancementDecision[]
  editorialPlacements EditorialPlacement[]

  @@index([status, startAt])
}

model Stage {
  id                 String      @id @default(cuid())
  seasonId           String
  season             Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  slug               String
  title              String
  description        String?
  orderIndex         Int
  stageType          StageType
  status             StageStatus @default(DRAFT)
  submissionsOpenAt  DateTime?
  submissionsCloseAt DateTime?
  judgingOpenAt      DateTime?
  judgingCloseAt     DateTime?
  votingOpenAt       DateTime?
  votingCloseAt      DateTime?
  resultsAt          DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  episodes           Episode[]
  auditionWindows    AuditionWindow[]
  performances         Performance[]
  stageResults         StageResult[]
  advancementDecisions AdvancementDecision[]
  editorialPlacements EditorialPlacement[]
  aiOutputs            AIOutput[]

  @@unique([seasonId, slug])
  @@unique([seasonId, orderIndex])
  @@index([seasonId, status, orderIndex])
}

model Episode {
  id          String        @id @default(cuid())
  seasonId    String
  season      Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  stageId     String?
  stage       Stage?        @relation(fields: [stageId], references: [id], onDelete: SetNull)
  slug        String
  title       String
  description String?
  orderIndex  Int
  status      EpisodeStatus @default(DRAFT)
  premiereAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([seasonId, slug])
  @@unique([seasonId, orderIndex])
  @@index([seasonId, status, premiereAt])
  @@index([stageId, status, premiereAt])
  performances Performance[]
  editorialPlacements EditorialPlacement[]
  aiOutputs            AIOutput[]
}

/// BETALENT show identity for a participant — not the same as `User` (account).
model Contestant {
  id          String           @id @default(cuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  username    String
  city        String?
  country     String?
  status      ContestantStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime       @updatedAt
  performances         Performance[]
  stageResultEntries   StageResultEntry[]
  advancementDecisions AdvancementDecision[]
  editorialPlacements  EditorialPlacement[]

  @@index([status])
}

/// Official show object — not a casual upload or feed item.
model Performance {
  id                         String               @id @default(cuid())
  contestantId               String
  contestant                 Contestant           @relation(fields: [contestantId], references: [id], onDelete: Cascade)
  seasonId                   String
  season                     Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  stageId                    String?
  stage                      Stage?               @relation(fields: [stageId], references: [id], onDelete: SetNull)
  episodeId                  String?
  episode                    Episode?             @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  submissionId               String?
  submission                 Submission?          @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  sourceAuditionSubmissionId String?            @unique
  sourceAuditionSubmission   AuditionSubmission?  @relation(fields: [sourceAuditionSubmissionId], references: [id], onDelete: SetNull)
  title                      String
  description                String?
  performanceType            PerformanceKind
  status                     PerformanceStatus    @default(DRAFT)
  /// Temporary pointer copied from audition `externalMediaRef` until real media pipeline exists.
  mediaRef                   String?
  publishedAt                DateTime?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  @@index([seasonId, status])
  @@index([contestantId, seasonId])
  @@index([stageId])
  @@index([episodeId])
  stageResultEntries   StageResultEntry[]
  advancementDecisions AdvancementDecision[]
  editorialPlacements EditorialPlacement[]
  aiOutputs            AIOutput[]
}

/// Publishable result package for a stage — public truth boundary when PUBLISHED.
model StageResult {
  id          String             @id @default(cuid())
  seasonId    String
  season      Season             @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  stageId     String
  stage       Stage              @relation(fields: [stageId], references: [id], onDelete: Cascade)
  title       String
  summary     String?
  status      StageResultStatus  @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  entries     StageResultEntry[]
  advancementDecisions AdvancementDecision[]
  editorialPlacements EditorialPlacement[]
  aiOutputs            AIOutput[]

  @@index([seasonId, stageId, status])
  @@index([status, publishedAt])
}

/// Ordered row in a published/ prep result package — explicit placement, not inferred.
model StageResultEntry {
  id             String       @id @default(cuid())
  stageResultId  String
  stageResult    StageResult  @relation(fields: [stageResultId], references: [id], onDelete: Cascade)
  performanceId  String
  performance    Performance  @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  contestantId   String
  contestant     Contestant   @relation(fields: [contestantId], references: [id], onDelete: Cascade)
  placementOrder Int
  highlightLabel String?
  createdAt      DateTime     @default(now())

  @@unique([stageResultId, placementOrder])
  @@unique([stageResultId, performanceId])
  @@index([stageResultId])
}

/// Official outcome for a contestant / optional performance — may exist before public release.
model AdvancementDecision {
  id               String                  @id @default(cuid())
  seasonId         String
  season           Season                  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  stageId          String
  stage            Stage                   @relation(fields: [stageId], references: [id], onDelete: Cascade)
  contestantId     String
  contestant       Contestant              @relation(fields: [contestantId], references: [id], onDelete: Cascade)
  performanceId    String?
  performance      Performance?            @relation(fields: [performanceId], references: [id], onDelete: SetNull)
  decision         AdvancementDecisionKind
  decidedAt        DateTime
  note             String?
  stageResultId    String?
  stageResult      StageResult?            @relation(fields: [stageResultId], references: [id], onDelete: SetNull)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([seasonId, stageId])
  @@index([contestantId, decidedAt])
  @@index([stageResultId])
}

/// Curated placement target — manual show-runner control, separate from official results.
model EditorialSlot {
  id          String               @id @default(cuid())
  slotKey     String               @unique
  title       String
  description String?
  pageScope   EditorialPageScope
  status      EditorialSlotStatus  @default(ACTIVE)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  placements  EditorialPlacement[]

  @@index([pageScope, status])
}

/// What appears in a slot — only PUBLISHED rows are public presentation truth.
model EditorialPlacement {
  id               String                   @id @default(cuid())
  editorialSlotId  String
  editorialSlot    EditorialSlot            @relation(fields: [editorialSlotId], references: [id], onDelete: Cascade)
  targetType       EditorialTargetType
  seasonId         String?
  season           Season?                  @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  stageId          String?
  stage            Stage?                   @relation(fields: [stageId], references: [id], onDelete: SetNull)
  episodeId        String?
  episode          Episode?                 @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  performanceId    String?
  performance      Performance?             @relation(fields: [performanceId], references: [id], onDelete: SetNull)
  contestantId     String?
  contestant       Contestant?             @relation(fields: [contestantId], references: [id], onDelete: SetNull)
  stageResultId    String?
  stageResult      StageResult?             @relation(fields: [stageResultId], references: [id], onDelete: SetNull)
  headline         String?
  subheadline      String?
  ctaLabel         String?
  sortOrder        Int?
  status           EditorialPlacementStatus @default(DRAFT)
  publishedAt      DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  aiOutputs        AIOutput[]

  @@index([editorialSlotId, status])
  @@index([status, publishedAt])
  @@index([editorialSlotId, sortOrder])
}

/// Persisted AI-generated copy — separate from StageResult / AdvancementDecision / editorial placement truth.
model AIOutput {
  id                   String             @id @default(cuid())
  kind                 AIOutputKind
  targetType           AIOutputTargetType
  performanceId        String?
  performance          Performance?       @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  stageId              String?
  stage                Stage?             @relation(fields: [stageId], references: [id], onDelete: Cascade)
  episodeId            String?
  episode              Episode?           @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  stageResultId        String?
  stageResult          StageResult?       @relation(fields: [stageResultId], references: [id], onDelete: Cascade)
  editorialPlacementId String?
  editorialPlacement   EditorialPlacement? @relation(fields: [editorialPlacementId], references: [id], onDelete: Cascade)
  status               AIOutputStatus     @default(DRAFT)
  promptVersion        String?
  title                String?
  body                 String             @db.Text
  metaJson             Json?
  generatedAt          DateTime?
  publishedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([kind, status, updatedAt])
  @@index([kind, targetType, performanceId])
  @@index([kind, targetType, stageId])
  @@index([kind, targetType, episodeId])
  @@index([kind, targetType, stageResultId])
  @@index([kind, targetType, editorialPlacementId])
}

model AuditionWindow {
  id                   String               @id @default(cuid())
  seasonId             String?
  season               Season?              @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  stageId              String?
  stage                Stage?               @relation(fields: [stageId], references: [id], onDelete: SetNull)
  slug                 String               @unique
  title                String
  description          String?
  status               AuditionWindowStatus @default(DRAFT)
  opensAt              DateTime
  closesAt             DateTime
  reviewStartsAt       DateTime?
  reviewEndsAt         DateTime?
  maxSubmissionsPerUser Int?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  submissions          AuditionSubmission[]

  @@index([status, opensAt, closesAt])
  @@index([seasonId])
  @@index([stageId])
}

/// Formal audition entry — `externalMediaRef` is temporary until upload pipeline exists.
model AuditionSubmission {
  id                String                   @id @default(cuid())
  auditionWindowId  String
  auditionWindow    AuditionWindow           @relation(fields: [auditionWindowId], references: [id], onDelete: Cascade)
  userId            String
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  submissionType    AuditionSubmissionType
  rightsStatus      AuditionRightsStatus     @default(UNKNOWN)
  status            AuditionSubmissionStatus @default(DRAFT)
  /// Temporary: user-supplied URL or opaque ref — not processed by BETALENT yet.
  externalMediaRef  String?
  /// BETALENT-stored media for the submission.
  mediaUrl          String?
  mediaOriginalName String?
  mediaSize         Int?
  mediaMimeType     String?
  notes             String?
  submittedAt       DateTime?
  reviewedAt        DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  reviews             AuditionReview[]
  officialPerformance Performance?

  @@index([auditionWindowId, userId])
  @@index([userId, status])
  @@index([auditionWindowId, status])
}

model AuditionReview {
  id                   String                     @id @default(cuid())
  auditionSubmissionId String
  auditionSubmission   AuditionSubmission         @relation(fields: [auditionSubmissionId], references: [id], onDelete: Cascade)
  reviewerUserId       String?
  reviewer             User?                      @relation("AuditionReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  status               AuditionReviewDecisionStatus
  decisionNote         String?
  createdAt            DateTime                   @default(now())

  @@index([auditionSubmissionId, createdAt])
  @@index([reviewerUserId])
}

model VideoAsset {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        VideoAssetProvider @default(R2_OBJECT)
  providerAssetId String?            @unique
  filename        String
  originalName    String
  url             String?
  uploadUrl       String?
  previewUrl      String?
  playbackUrl     String?
  thumbnailUrl    String?
  size            Int
  mimeType        String
  originalityConfirmed Boolean       @default(false)
  originalityConfirmedAt DateTime?
  originalityDeclarationText String?
  status          VideoAssetStatus   @default(UPLOADING)
  errorCode       String?
  errorMessage    String?
  readyAt         DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  submissions Submission[]

  @@index([provider, providerAssetId])
  @@index([userId, status])
}

model Submission {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoAssetId String
  videoAsset  VideoAsset       @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      SubmissionStatus @default(DRAFT)
  submittedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  judgeResults JudgeResult[]
  performances Performance[]
  likes       SubmissionLike[]
  viewEvents  SubmissionViewEvent[]
  engagementStat SubmissionEngagementStat?

  @@index([userId, status])
  @@index([videoAssetId])
}

model SubmissionLike {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([submissionId, userId])
  @@index([submissionId, createdAt])
  @@index([userId, createdAt])
}

model CreatorFollow {
  id         String   @id @default(cuid())
  followerId String
  follower   User     @relation("CreatorFollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  creatorId  String
  creator    User     @relation("CreatorFollowCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([followerId, creatorId])
  @@index([creatorId, createdAt])
  @@index([followerId, createdAt])
}

model SubmissionViewEvent {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  viewerUserId String
  viewerUser   User       @relation(fields: [viewerUserId], references: [id], onDelete: Cascade)
  viewerKey    String
  dayBucket    DateTime
  viewedAt     DateTime   @default(now())

  @@unique([submissionId, viewerKey, dayBucket])
  @@index([submissionId, viewedAt])
  @@index([viewerUserId, viewedAt])
}

model SubmissionEngagementStat {
  submissionId String     @id
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  likeCount    Int        @default(0)
  viewCount    Int        @default(0)
  updatedAt    DateTime   @updatedAt
}

model UserEngagementStat {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  followerCount  Int      @default(0)
  followingCount Int      @default(0)
  updatedAt      DateTime @updatedAt
}

model JudgeResult {
  id           String            @id @default(cuid())
  submissionId String
  submission   Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  judgeUserId  String
  judge        User              @relation(fields: [judgeUserId], references: [id], onDelete: Cascade)
  score        Int?
  feedback     String?
  status       JudgeResultStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  advancements Advancement[]

  @@index([submissionId])
  @@index([judgeUserId])
}

model Advancement {
  id           String            @id @default(cuid())
  judgeResultId String
  judgeResult  JudgeResult       @relation(fields: [judgeResultId], references: [id], onDelete: Cascade)
  decision     AdvancementStatus @default(PENDING)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([judgeResultId])
}

model ArchiveRecord {
  id          String              @id @default(cuid())
  entityType  String
  entityId    String
  data        Json
  status      ArchiveRecordStatus @default(ACTIVE)
  archivedAt  DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([entityType, entityId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entityType String
  entityId  String
  details   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId, status])
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  toEmail   String
  subject   String
  body      String
  sentAt    DateTime?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([toEmail])
}

model CreatorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?
  website     String?
  socialLinks Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
