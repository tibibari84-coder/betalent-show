// BETALENT — auth, onboarding, and show orchestration backbone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SeasonStatus {
  DRAFT
  UPCOMING
  LIVE
  COMPLETED
  ARCHIVED
}

enum StageType {
  AUDITION
  CALLBACK
  SEMIFINAL
  FINAL
  SPECIAL
}

enum StageStatus {
  DRAFT
  UPCOMING
  OPEN
  JUDGING
  VOTING
  RESULTS
  COMPLETED
  ARCHIVED
}

enum EpisodeStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  displayName           String?
  username              String?   @unique
  city                  String?
  country               String?
  wantsToAudition       Boolean   @default(false)
  onboardingCompletedAt DateTime?
  emailVerifiedAt       DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  sessions              Session[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Season {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String?
  status      SeasonStatus @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  stages      Stage[]
  episodes    Episode[]

  @@index([status, startAt])
}

model Stage {
  id                 String      @id @default(cuid())
  seasonId           String
  season             Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  slug               String
  title              String
  description        String?
  orderIndex         Int
  stageType          StageType
  status             StageStatus @default(DRAFT)
  submissionsOpenAt  DateTime?
  submissionsCloseAt DateTime?
  judgingOpenAt      DateTime?
  judgingCloseAt     DateTime?
  votingOpenAt       DateTime?
  votingCloseAt      DateTime?
  resultsAt          DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  episodes           Episode[]

  @@unique([seasonId, slug])
  @@unique([seasonId, orderIndex])
  @@index([seasonId, status, orderIndex])
}

model Episode {
  id          String        @id @default(cuid())
  seasonId    String
  season      Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  stageId     String?
  stage       Stage?        @relation(fields: [stageId], references: [id], onDelete: SetNull)
  slug        String
  title       String
  description String?
  orderIndex  Int
  status      EpisodeStatus @default(DRAFT)
  premiereAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([seasonId, slug])
  @@unique([seasonId, orderIndex])
  @@index([seasonId, status, premiereAt])
  @@index([stageId, status, premiereAt])
}
