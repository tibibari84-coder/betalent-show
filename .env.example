# BETALENT core app
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database / production runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Cloudflare Stream
# Required for direct upload initialization:
# - CLOUDFLARE_STREAM_ACCOUNT_ID
# - CLOUDFLARE_STREAM_API_TOKEN
# - NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN
# Required additionally for verified READY / FAILED handling:
# - CLOUDFLARE_STREAM_WEBHOOK_SECRET
CLOUDFLARE_STREAM_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=

# Cloudflare R2
# Required for signed upload URLs:
# - R2_PROVIDER=cloudflare
# - R2_ACCOUNT_ID
# - R2_BUCKET_NAME
# - R2_ACCESS_KEY_ID
# - R2_SECRET_ACCESS_KEY
# Required additionally for avatar/profile/static public delivery:
# - R2_PUBLIC_BASE_URL
R2_PROVIDER=cloudflare
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Sentry
# Required at runtime:
# - SENTRY_DSN
# - NEXT_PUBLIC_SENTRY_DSN
# Required on CI / Vercel for source map upload:
# - SENTRY_ORG
# - SENTRY_PROJECT
# - SENTRY_AUTH_TOKEN
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog
# Server events require POSTHOG_API_KEY.
# Client analytics require NEXT_PUBLIC_POSTHOG_KEY.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Resend
# Required to send real emails:
# - RESEND_API_KEY
# - RESEND_FROM_EMAIL
RESEND_API_KEY=
RESEND_FROM_EMAIL=BETALENT <no-reply@example.com>

# Optional AI foundation
OPENAI_API_KEY=
BETALENT_AI_MODEL=gpt-4o-mini
