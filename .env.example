# PostgreSQL — required when running Prisma migrate/db push against a real DB
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Client-visible environment label (e.g. development | staging | production)
NEXT_PUBLIC_APP_ENV="development"

# Server-side OpenAI — required for internal AI generation tools (Judge / Host / Producer)
OPENAI_API_KEY=""
# Optional override (default: gpt-4o-mini)
BETALENT_AI_MODEL=""

# Cloudflare R2 — reserved for future media workflows — not wired in this phase
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
