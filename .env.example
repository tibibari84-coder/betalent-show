# PostgreSQL — required when running Prisma migrate/db push against a real DB
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Client-visible environment label (e.g. development | staging | production)
NEXT_PUBLIC_APP_ENV="development"

# Reserved for future AI integrations — not wired in this phase
OPENAI_API_KEY=""

# Cloudflare R2 — reserved for future media workflows — not wired in this phase
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
